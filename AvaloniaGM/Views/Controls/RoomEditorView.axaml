<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaGM.ViewModels"
             xmlns:controls="using:AvaloniaGM.Views.Controls"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
             x:Class="AvaloniaGM.Views.Controls.RoomEditorView"
             x:DataType="vm:RoomEditorViewModel">

    <UserControl.Styles>
        <Style Selector="ToggleButton.room-toolbar-toggle">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="ToggleButton.room-toolbar-toggle:pointerover">
            <Setter Property="Background" Value="#FFF0F4FA" />
            <Setter Property="BorderBrush" Value="#FFD5DFEC" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="ToggleButton.room-toolbar-toggle:checked">
            <Setter Property="Background" Value="#FFE3EBF6" />
            <Setter Property="BorderBrush" Value="#FFC5D3E4" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="ToggleButton.room-toolbar-toggle:pressed">
            <Setter Property="Background" Value="#FFD8E3F0" />
            <Setter Property="BorderBrush" Value="#FFB7C8DC" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="400,*"
          Margin="12">
        <Border Grid.Column="0"
                Margin="0,0,12,0"
                Padding="14"
                BorderBrush="#FFD6D6D6"
                BorderThickness="1"
                Background="#FFFBFBFB"
                CornerRadius="4">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12"
                            Margin="0,0,20,0">
                    <TextBlock Text="Room Properties"
                               FontSize="18"
                               FontWeight="SemiBold" />

                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="8">
                        <TextBlock Grid.Row="0"
                                   VerticalAlignment="Center"
                                   Text="Name" />
                        <TextBox Grid.Row="0"
                                 Grid.Column="1"
                                 IsReadOnly="True"
                                 Text="{Binding Name}" />

                        <TextBlock Grid.Row="1"
                                   VerticalAlignment="Center"
                                   Text="Caption" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Text="{Binding Caption}" />

                        <TextBlock Grid.Row="2"
                                   VerticalAlignment="Center"
                                   Text="Width" />
                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 Text="{Binding Width}" />

                        <TextBlock Grid.Row="3"
                                   VerticalAlignment="Center"
                                   Text="Height" />
                        <TextBox Grid.Row="3"
                                 Grid.Column="1"
                                 Text="{Binding Height}" />

                        <TextBlock Grid.Row="4"
                                   VerticalAlignment="Center"
                                   Text="Speed" />
                        <TextBox Grid.Row="4"
                                 Grid.Column="1"
                                 Text="{Binding Speed}" />

                        <TextBlock Grid.Row="5"
                                   VerticalAlignment="Center"
                                   Text="Colour" />
                        <TextBox Grid.Row="5"
                                 Grid.Column="1"
                                 Text="{Binding Colour}" />
                    </Grid>

                    <StackPanel Spacing="6">
                        <CheckBox Content="Persistent"
                                  IsChecked="{Binding Persistent}" />
                        <CheckBox Content="Replace Instances On Paint"
                                  IsChecked="{Binding DeleteUnderlyingObj}" />
                        <CheckBox Content="Replace Tiles On Paint"
                                  IsChecked="{Binding DeleteUnderlyingTiles}" />
                    </StackPanel>

                    <TextBlock Text="Editing"
                               FontSize="16"
                               FontWeight="SemiBold" />

                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto"
                          ColumnSpacing="10">
                        <TextBlock VerticalAlignment="Center"
                                   Text="Layer" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding LayerOptions}"
                                  SelectedItem="{Binding ActiveLayer}" />
                    </Grid>

                    <TextBlock Text="{Binding PlacementHint}"
                               Foreground="#FF666666"
                               TextWrapping="Wrap" />

                    <StackPanel Spacing="10"
                                IsVisible="{Binding IsEditingInstances}">
                        <TextBlock Text="Object"
                                   FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding ObjectOptions}"
                                  SelectedItem="{Binding SelectedObjectOption}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Border Padding="10"
                                BorderBrush="#FFE0E0E0"
                                BorderThickness="1"
                                Background="#FFF7F7F7"
                                CornerRadius="4"
                                IsVisible="{Binding HasSelectedInstance}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Selected Instance"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedInstanceObjectName}"
                                           Foreground="#FF666666" />

                                <Grid ColumnDefinitions="Auto,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                      ColumnSpacing="10"
                                      RowSpacing="8">
                                    <TextBlock Grid.Row="0"
                                               VerticalAlignment="Center"
                                               Text="X" />
                                    <TextBox Grid.Row="0"
                                             Grid.Column="1"
                                             Text="{Binding SelectedInstanceX}" />

                                    <TextBlock Grid.Row="1"
                                               VerticalAlignment="Center"
                                               Text="Y" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Text="{Binding SelectedInstanceY}" />

                                    <TextBlock Grid.Row="2"
                                               VerticalAlignment="Center"
                                               Text="Scale X" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Text="{Binding SelectedInstanceScaleX}" />

                                    <TextBlock Grid.Row="3"
                                               VerticalAlignment="Center"
                                               Text="Scale Y" />
                                    <TextBox Grid.Row="3"
                                             Grid.Column="1"
                                             Text="{Binding SelectedInstanceScaleY}" />

                                    <TextBlock Grid.Row="4"
                                               VerticalAlignment="Center"
                                               Text="Rotation" />
                                    <TextBox Grid.Row="4"
                                             Grid.Column="1"
                                             Text="{Binding SelectedInstanceRotation}" />
                                </Grid>

                                <TextBlock Text="Creation Code"
                                           FontWeight="SemiBold" />

                                <controls:GmlCodeEditorView Height="220"
                                                            DataContext="{Binding SelectedInstanceCodeDocument}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="10"
                                IsVisible="{Binding IsEditingTiles}">
                        <TextBlock Text="Tileset"
                                   FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding BackgroundOptions}"
                                  SelectedItem="{Binding SelectedBackgroundOption}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Grid ColumnDefinitions="Auto,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                              ColumnSpacing="10"
                              RowSpacing="8">
                            <TextBlock Grid.Row="0"
                                       VerticalAlignment="Center"
                                       Text="Source X" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Text="{Binding TileSourceX}" />

                            <TextBlock Grid.Row="1"
                                       VerticalAlignment="Center"
                                       Text="Source Y" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Text="{Binding TileSourceY}" />

                            <TextBlock Grid.Row="2"
                                       VerticalAlignment="Center"
                                       Text="Tile Width" />
                            <TextBox Grid.Row="2"
                                     Grid.Column="1"
                                     Text="{Binding TileWidth}" />

                            <TextBlock Grid.Row="3"
                                       VerticalAlignment="Center"
                                       Text="Tile Height" />
                            <TextBox Grid.Row="3"
                                     Grid.Column="1"
                                     Text="{Binding TileHeight}" />

                            <TextBlock Grid.Row="4"
                                       VerticalAlignment="Center"
                                       Text="Depth" />
                            <TextBox Grid.Row="4"
                                     Grid.Column="1"
                                     Text="{Binding TileDepth}" />
                        </Grid>

                        <Border Height="220"
                                BorderBrush="#FFE0E0E0"
                                BorderThickness="1"
                                Background="#FF242424"
                                CornerRadius="4">
                            <controls:RoomTilesetPickerView RenderOptions.BitmapInterpolationMode="None" />
                        </Border>

                        <Border Padding="10"
                                BorderBrush="#FFE0E0E0"
                                BorderThickness="1"
                                Background="#FFF7F7F7"
                                CornerRadius="4"
                                IsVisible="{Binding HasSelectedTile}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Selected Tile"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedTileBackgroundName}"
                                           Foreground="#FF666666" />

                                <Grid ColumnDefinitions="Auto,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                      ColumnSpacing="10"
                                      RowSpacing="8">
                                    <TextBlock Grid.Row="0"
                                               VerticalAlignment="Center"
                                               Text="X" />
                                    <TextBox Grid.Row="0"
                                             Grid.Column="1"
                                             Text="{Binding SelectedTileX}" />

                                    <TextBlock Grid.Row="1"
                                               VerticalAlignment="Center"
                                               Text="Y" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Text="{Binding SelectedTileY}" />

                                    <TextBlock Grid.Row="2"
                                               VerticalAlignment="Center"
                                               Text="Width" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Text="{Binding SelectedTileWidth}" />

                                    <TextBlock Grid.Row="3"
                                               VerticalAlignment="Center"
                                               Text="Height" />
                                    <TextBox Grid.Row="3"
                                             Grid.Column="1"
                                             Text="{Binding SelectedTileHeight}" />

                                    <TextBlock Grid.Row="4"
                                               VerticalAlignment="Center"
                                               Text="Source X" />
                                    <TextBox Grid.Row="4"
                                             Grid.Column="1"
                                             Text="{Binding SelectedTileSourceX}" />

                                    <TextBlock Grid.Row="5"
                                               VerticalAlignment="Center"
                                               Text="Source Y" />
                                    <TextBox Grid.Row="5"
                                             Grid.Column="1"
                                             Text="{Binding SelectedTileSourceY}" />

                                    <TextBlock Grid.Row="6"
                                               VerticalAlignment="Center"
                                               Text="Scale X/Y" />
                                    <Grid Grid.Row="6"
                                          Grid.Column="1"
                                          ColumnDefinitions="*,8,*">
                                        <TextBox Text="{Binding SelectedTileScaleX}" />
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding SelectedTileScaleY}" />
                                    </Grid>

                                    <TextBlock Grid.Row="7"
                                               VerticalAlignment="Center"
                                               Text="Depth" />
                                    <TextBox Grid.Row="7"
                                             Grid.Column="1"
                                             Text="{Binding SelectedTileDepth}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Expander Header="Background Layers"
                              IsExpanded="True">
                        <ItemsControl ItemsSource="{Binding RoomBackgroundSlots}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RoomBackgroundSlotViewModel">
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            BorderBrush="#FFE0E0E0"
                                            BorderThickness="1"
                                            Background="#FFF8F8F8"
                                            CornerRadius="4">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="{Binding Header}"
                                                       FontWeight="SemiBold" />

                                            <ComboBox ItemsSource="{Binding BackgroundOptions}"
                                                      SelectedItem="{Binding BackgroundOption}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding DisplayName}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>

                                            <WrapPanel Orientation="Horizontal"
                                                       ItemHeight="28"
                                                       ItemWidth="130">
                                                <CheckBox Content="Visible"
                                                          IsChecked="{Binding Visible}" />
                                                <CheckBox Content="Foreground"
                                                          IsChecked="{Binding Foreground}" />
                                                <CheckBox Content="H Tiled"
                                                          IsChecked="{Binding HTiled}" />
                                                <CheckBox Content="V Tiled"
                                                          IsChecked="{Binding VTiled}" />
                                                <CheckBox Content="Stretch"
                                                          IsChecked="{Binding Stretch}" />
                                            </WrapPanel>

                                            <Grid ColumnDefinitions="Auto,*,Auto,*"
                                                  RowDefinitions="Auto,Auto"
                                                  ColumnSpacing="8"
                                                  RowSpacing="8">
                                                <TextBlock VerticalAlignment="Center"
                                                           Text="X" />
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding X}" />

                                                <TextBlock Grid.Column="2"
                                                           VerticalAlignment="Center"
                                                           Text="Y" />
                                                <TextBox Grid.Column="3"
                                                         Text="{Binding Y}" />

                                                <TextBlock Grid.Row="1"
                                                           VerticalAlignment="Center"
                                                           Text="H Speed" />
                                                <TextBox Grid.Row="1"
                                                         Grid.Column="1"
                                                         Text="{Binding HSpeed}" />

                                                <TextBlock Grid.Row="1"
                                                           Grid.Column="2"
                                                           VerticalAlignment="Center"
                                                           Text="V Speed" />
                                                <TextBox Grid.Row="1"
                                                         Grid.Column="3"
                                                         Text="{Binding VSpeed}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <Expander Header="Views"
                              IsExpanded="False">
                        <StackPanel Spacing="8">
                            <WrapPanel Orientation="Horizontal"
                                       ItemHeight="28"
                                       ItemWidth="150">
                                <CheckBox Content="Enable Views"
                                          IsChecked="{Binding EnableViews}" />
                                <CheckBox Content="Clear Screen"
                                          IsChecked="{Binding ViewClearScreen}" />
                                <CheckBox Content="Clear Display Buffer"
                                          IsChecked="{Binding ClearDisplayBuffer}" />
                            </WrapPanel>

                            <ItemsControl ItemsSource="{Binding RoomViewSlots}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RoomViewSlotViewModel">
                                        <Border Margin="0,0,0,8"
                                                Padding="10"
                                                BorderBrush="#FFE0E0E0"
                                                BorderThickness="1"
                                                Background="#FFF8F8F8"
                                                CornerRadius="4">
                                            <StackPanel Spacing="8">
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Left"
                                                               Text="{Binding Header}"
                                                               FontWeight="SemiBold" />
                                                    <CheckBox DockPanel.Dock="Right"
                                                              Content="Visible"
                                                              IsChecked="{Binding Visible}" />
                                                </DockPanel>

                                                <ComboBox ItemsSource="{Binding FollowObjectOptions}"
                                                          SelectedItem="{Binding FollowObjectOption}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding DisplayName}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>

                                                <Grid ColumnDefinitions="Auto,*,Auto,*"
                                                      RowDefinitions="Auto,Auto,Auto,Auto"
                                                      ColumnSpacing="8"
                                                      RowSpacing="8">
                                                    <TextBlock VerticalAlignment="Center"
                                                               Text="X View" />
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding XView}" />

                                                    <TextBlock Grid.Column="2"
                                                               VerticalAlignment="Center"
                                                               Text="Y View" />
                                                    <TextBox Grid.Column="3"
                                                             Text="{Binding YView}" />

                                                    <TextBlock Grid.Row="1"
                                                               VerticalAlignment="Center"
                                                               Text="W View" />
                                                    <TextBox Grid.Row="1"
                                                             Grid.Column="1"
                                                             Text="{Binding WView}" />

                                                    <TextBlock Grid.Row="1"
                                                               Grid.Column="2"
                                                               VerticalAlignment="Center"
                                                               Text="H View" />
                                                    <TextBox Grid.Row="1"
                                                             Grid.Column="3"
                                                             Text="{Binding HView}" />

                                                    <TextBlock Grid.Row="2"
                                                               VerticalAlignment="Center"
                                                               Text="X Port" />
                                                    <TextBox Grid.Row="2"
                                                             Grid.Column="1"
                                                             Text="{Binding XPort}" />

                                                    <TextBlock Grid.Row="2"
                                                               Grid.Column="2"
                                                               VerticalAlignment="Center"
                                                               Text="Y Port" />
                                                    <TextBox Grid.Row="2"
                                                             Grid.Column="3"
                                                             Text="{Binding YPort}" />

                                                    <TextBlock Grid.Row="3"
                                                               VerticalAlignment="Center"
                                                               Text="W Port" />
                                                    <TextBox Grid.Row="3"
                                                             Grid.Column="1"
                                                             Text="{Binding WPort}" />

                                                    <TextBlock Grid.Row="3"
                                                               Grid.Column="2"
                                                               VerticalAlignment="Center"
                                                               Text="H Port" />
                                                    <TextBox Grid.Row="3"
                                                             Grid.Column="3"
                                                             Text="{Binding HPort}" />
                                                </Grid>

                                                <Grid ColumnDefinitions="Auto,*,Auto,*"
                                                      RowDefinitions="Auto,Auto"
                                                      ColumnSpacing="8"
                                                      RowSpacing="8">
                                                    <TextBlock VerticalAlignment="Center"
                                                               Text="H Border" />
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding HBorder}" />

                                                    <TextBlock Grid.Column="2"
                                                               VerticalAlignment="Center"
                                                               Text="V Border" />
                                                    <TextBox Grid.Column="3"
                                                             Text="{Binding VBorder}" />

                                                    <TextBlock Grid.Row="1"
                                                               VerticalAlignment="Center"
                                                               Text="H Speed" />
                                                    <TextBox Grid.Row="1"
                                                             Grid.Column="1"
                                                             Text="{Binding HSpeed}" />

                                                    <TextBlock Grid.Row="1"
                                                               Grid.Column="2"
                                                               VerticalAlignment="Center"
                                                               Text="V Speed" />
                                                    <TextBox Grid.Row="1"
                                                             Grid.Column="3"
                                                             Text="{Binding VSpeed}" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="1"
                Padding="12"
                BorderBrush="#FFD6D6D6"
                BorderThickness="1"
                Background="#FFFDFDFD"
                CornerRadius="4">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="12">
                <Border Padding="10"
                        BorderBrush="#FFE0E0E0"
                        BorderThickness="1"
                        Background="#FFF5F5F5"
                        CornerRadius="4">
                    <Grid ColumnDefinitions="Auto,60,10,Auto,60,18,Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="8">
                        <TextBlock VerticalAlignment="Center"
                                   Text="H Snap" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding HSnap}" />

                        <TextBlock Grid.Column="3"
                                   VerticalAlignment="Center"
                                   Text="V Snap" />
                        <TextBox Grid.Column="4"
                                 Text="{Binding VSnap}" />

                        <ToggleButton Grid.Column="6"
                                      Classes="room-toolbar-toggle"
                                      IsChecked="{Binding ShowColour}"
                                      ToolTip.Tip="Show Room Colour">
                            <Image Width="16"
                                   Height="16"
                                   Stretch="Uniform">
                                <Image.Source>
                                    <svg:SvgImage Source="/Assets/Icons/Fluent/Room/color-fill.svg" />
                                </Image.Source>
                            </Image>
                        </ToggleButton>

                        <ToggleButton Grid.Column="7"
                                      Classes="room-toolbar-toggle"
                                      IsChecked="{Binding ShowGrid}"
                                      ToolTip.Tip="Show Grid">
                            <Image Width="16"
                                   Height="16"
                                   Stretch="Uniform">
                                <Image.Source>
                                    <svg:SvgImage Source="/Assets/Icons/Fluent/Tree/grid.svg" />
                                </Image.Source>
                            </Image>
                        </ToggleButton>

                        <ToggleButton Grid.Column="8"
                                      Classes="room-toolbar-toggle"
                                      IsChecked="{Binding ShowObjects}"
                                      ToolTip.Tip="Show Objects">
                            <Image Width="16"
                                   Height="16"
                                   Stretch="Uniform">
                                <Image.Source>
                                    <svg:SvgImage Source="/Assets/Icons/Fluent/Tree/cube.svg" />
                                </Image.Source>
                            </Image>
                        </ToggleButton>

                        <ToggleButton Grid.Column="9"
                                      Classes="room-toolbar-toggle"
                                      IsChecked="{Binding ShowTiles}"
                                      ToolTip.Tip="Show Tiles">
                            <Image Width="16"
                                   Height="16"
                                   Stretch="Uniform">
                                <Image.Source>
                                    <svg:SvgImage Source="/Assets/Icons/Fluent/Tree/grid.svg" />
                                </Image.Source>
                            </Image>
                        </ToggleButton>

                        <ToggleButton Grid.Column="10"
                                      Classes="room-toolbar-toggle"
                                      IsChecked="{Binding ShowBackgrounds}"
                                      ToolTip.Tip="Show Backgrounds">
                            <Image Width="16"
                                   Height="16"
                                   Stretch="Uniform">
                                <Image.Source>
                                    <svg:SvgImage Source="/Assets/Icons/Fluent/Tree/image.svg" />
                                </Image.Source>
                            </Image>
                        </ToggleButton>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        BorderBrush="#FFCDCDCD"
                        BorderThickness="1"
                        Background="#FF2A2A2A"
                        CornerRadius="4"
                        ClipToBounds="True">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <controls:RoomCanvasView Width="{Binding CanvasWidth}"
                                                 Height="{Binding CanvasHeight}"
                                                 RenderOptions.BitmapInterpolationMode="None" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
