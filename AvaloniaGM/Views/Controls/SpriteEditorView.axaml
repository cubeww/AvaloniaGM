<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaGM.ViewModels"
             x:Class="AvaloniaGM.Views.Controls.SpriteEditorView"
             x:DataType="vm:SpriteEditorViewModel">

    <Grid ColumnDefinitions="320,*"
          RowDefinitions="*"
          Margin="12">
        <Border Grid.Column="0"
                Margin="0,0,12,0"
                Padding="14"
                BorderBrush="#FFD6D6D6"
                BorderThickness="1"
                Background="#FFFBFBFB"
                CornerRadius="4">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12"
                            Margin="0,0,20,0">
                    <TextBlock Text="Sprite Properties"
                               FontSize="18"
                               FontWeight="SemiBold" />

                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="8">
                        <TextBlock Grid.Row="0"
                                   VerticalAlignment="Center"
                                   Text="Name" />
                        <TextBox Grid.Row="0"
                                 Grid.Column="1"
                                 IsReadOnly="True"
                                 Text="{Binding Name}" />

                        <TextBlock Grid.Row="1"
                                   VerticalAlignment="Center"
                                   Text="Type" />
                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  ItemsSource="{Binding SpriteTypes}"
                                  SelectedItem="{Binding Type}" />

                        <TextBlock Grid.Row="2"
                                   VerticalAlignment="Center"
                                   Text="Size" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Text="{Binding SpriteSizeText}" />

                        <TextBlock Grid.Row="3"
                                   VerticalAlignment="Center"
                                   Text="X Origin" />
                        <TextBox Grid.Row="3"
                                 Grid.Column="1"
                                 Text="{Binding XOrigin}" />

                        <TextBlock Grid.Row="4"
                                   VerticalAlignment="Center"
                                   Text="Y Origin" />
                        <TextBox Grid.Row="4"
                                 Grid.Column="1"
                                 Text="{Binding YOrigin}" />

                        <TextBlock Grid.Row="5"
                                   VerticalAlignment="Center"
                                   Text="Collision Kind" />
                        <ComboBox Grid.Row="5"
                                  Grid.Column="1"
                                  ItemsSource="{Binding CollisionKinds}"
                                  SelectedItem="{Binding CollisionKind}" />

                        <TextBlock Grid.Row="6"
                                   VerticalAlignment="Center"
                                   Text="Collision Tolerance" />
                        <TextBox Grid.Row="6"
                                 Grid.Column="1"
                                 Text="{Binding CollisionTolerance}" />

                        <TextBlock Grid.Row="7"
                                   VerticalAlignment="Center"
                                   Text="Bounding Box" />
                        <ComboBox Grid.Row="7"
                                  Grid.Column="1"
                                  ItemsSource="{Binding BoundingBoxModes}"
                                  SelectedItem="{Binding BoundingBoxMode}" />

                        <TextBlock Grid.Row="8"
                                   VerticalAlignment="Center"
                                   Text="Frames" />
                        <TextBlock Grid.Row="8"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Text="{Binding FrameCount}" />
                    </Grid>

                    <StackPanel Spacing="6">
                        <CheckBox Content="Separate Collision Masks"
                                  IsChecked="{Binding SeparateCollisionMasks}" />
                        <CheckBox Content="Horizontal Tile"
                                  IsChecked="{Binding HTile}" />
                        <CheckBox Content="Vertical Tile"
                                  IsChecked="{Binding VTile}" />
                        <CheckBox Content="For 3D"
                                  IsChecked="{Binding For3D}" />
                        <CheckBox Content="Dynamic Texture Page"
                                  IsChecked="{Binding DynamicTexturePage}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1"
              RowDefinitions="*,Auto,*"
              RowSpacing="12">
            <Border Grid.Row="0"
                    Padding="12"
                    BorderBrush="#FFD6D6D6"
                    BorderThickness="1"
                    Background="#FFFDFDFD"
                    CornerRadius="4">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="{Binding SelectedFrameTitle}"
                               FontSize="16"
                               FontWeight="SemiBold" />

                    <Grid Grid.Row="1"
                          Margin="0,12,0,0">
                        <Border BorderBrush="#FFE0E0E0"
                                BorderThickness="1"
                                Background="#FFF4F4F4"
                                CornerRadius="4">
                            <Image Source="{Binding SelectedFrameBitmap}"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapInterpolationMode="None"
                                   Margin="12"
                                   IsVisible="{Binding HasSelectedFrame}" />
                        </Border>

                        <TextBlock Text="No sprite frame selected."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#FF666666"
                                   IsVisible="{Binding HasNoSelectedFrame}" />
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Spacing="8">
                <Button Click="AddFramesButton_OnClick">
                    Add Frames
                </Button>

                <Button Command="{Binding RemoveSelectedFrameCommand}">
                    Remove Selected Frame
                </Button>
            </StackPanel>

            <Border Grid.Row="2"
                    Padding="12"
                    BorderBrush="#FFD6D6D6"
                    BorderThickness="1"
                    Background="#FFFDFDFD"
                    CornerRadius="4">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="Frames"
                               FontSize="16"
                               FontWeight="SemiBold" />

                    <ListBox Grid.Row="1"
                             Margin="0,12,0,0"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemsSource="{Binding Frames}"
                             SelectedItem="{Binding SelectedFrame}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>

                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:SpriteFrameItemViewModel">
                                <Border Width="112"
                                        Padding="8"
                                        BorderBrush="#FFD8D8D8"
                                        BorderThickness="1"
                                        Background="#FFFFFFFF"
                                        CornerRadius="4">
                                    <StackPanel Spacing="6">
                                        <Border Height="72"
                                                BorderBrush="#FFE6E6E6"
                                                BorderThickness="1"
                                                Background="#FFF4F4F4"
                                                CornerRadius="3">
                                            <Image Source="{Binding Bitmap}"
                                                   RenderOptions.BitmapInterpolationMode="None"
                                                   Stretch="Uniform"
                                                   Margin="6" />
                                        </Border>

                                        <TextBlock Text="{Binding Header}"
                                                   HorizontalAlignment="Center"
                                                   FontWeight="SemiBold" />

                                        <TextBlock Text="{Binding SizeText}"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#FF666666" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
