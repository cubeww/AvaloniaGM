<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaGM.ViewModels"
        xmlns:controls="using:AvaloniaGM.Views.Controls"
        xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="AvaloniaGM.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1400"
        Height="900"
        MinWidth="960"
        MinHeight="640"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}"
        Background="#FFF3F3F3">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Resources>
        <DataTemplate x:Key="EditorTabHeaderTemplate"
                      x:DataType="vm:EditorTabViewModel">
            <TextBlock Text="{Binding Header}" />
        </DataTemplate>

        <DataTemplate x:Key="EditorTabContentTemplate"
                      x:DataType="vm:EditorTabViewModel">
            <ContentControl Content="{Binding EditorContent}" />
        </DataTemplate>
    </Window.Resources>

    <Window.DataTemplates>
        <DataTemplate DataType="vm:ResourceSummaryEditorViewModel">
            <Grid RowDefinitions="Auto,Auto,*"
                  Margin="16">
                <TextBlock Text="{Binding Header}"
                           FontSize="18"
                           FontWeight="SemiBold" />

                <TextBlock Grid.Row="1"
                           Margin="0,8,0,0"
                           Text="{Binding Subtitle}"
                           Foreground="#FF555555" />

                <Border Grid.Row="2"
                        Margin="0,16,0,0"
                        Padding="16"
                        BorderBrush="#FFC6C6C6"
                        BorderThickness="1"
                        Background="#FFFAFAFA">
                    <TextBlock Text="{Binding Content}"
                               TextWrapping="Wrap"
                               LineHeight="24" />
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="vm:SpriteEditorViewModel">
            <controls:SpriteEditorView />
        </DataTemplate>

        <DataTemplate DataType="vm:BackgroundEditorViewModel">
            <controls:BackgroundEditorView />
        </DataTemplate>

        <DataTemplate DataType="vm:SoundEditorViewModel">
            <controls:SoundEditorView />
        </DataTemplate>

        <DataTemplate DataType="vm:FontEditorViewModel">
            <controls:FontEditorView />
        </DataTemplate>

        <DataTemplate DataType="vm:ScriptEditorViewModel">
            <controls:ScriptEditorView />
        </DataTemplate>

        <DataTemplate DataType="vm:ObjectEditorViewModel">
            <controls:ObjectEditorView />
        </DataTemplate>

        <DataTemplate DataType="vm:TimelineEditorViewModel">
            <controls:TimelineEditorView />
        </DataTemplate>

        <DataTemplate DataType="vm:RoomEditorViewModel">
            <controls:RoomEditorView />
        </DataTemplate>
    </Window.DataTemplates>

    <Window.Styles>
        <Style Selector="Button.toolbar-button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="Button.toolbar-button:pointerover">
            <Setter Property="Background" Value="#FFF0F4FA" />
            <Setter Property="BorderBrush" Value="#FFD5DFEC" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Button.toolbar-button:pressed">
            <Setter Property="Background" Value="#FFE3EBF6" />
            <Setter Property="BorderBrush" Value="#FFC5D3E4" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*">
        <Menu Grid.Row="0"
              Background="#FFE7E7E7">
            <MenuItem Header="_File">
                <MenuItem Header="_New Project"
                          InputGesture="Ctrl+N"
                          Command="{Binding NewProjectCommand}" />
                <MenuItem Header="_Open Project"
                          InputGesture="Ctrl+O"
                          Click="OpenProjectMenuItem_OnClick" />
                <MenuItem Header="_Save Project"
                          InputGesture="Ctrl+S"
                          Click="SaveProjectMenuItem_OnClick" />
                <MenuItem Header="Save _As Project"
                          InputGesture="Ctrl+Shift+S"
                          Click="SaveProjectAsMenuItem_OnClick" />
            </MenuItem>

            <MenuItem Header="_Run">
                <MenuItem Header="_Run Project"
                          InputGesture="F5"
                          Command="{Binding RunProjectCommand}" />
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_About AvaloniaGM"
                          Command="{Binding ShowHelpCommand}" />
            </MenuItem>
        </Menu>

        <Border Grid.Row="1"
                BorderBrush="#FFC8C8C8"
                BorderThickness="0,1,0,1"
                Background="#FFEDEDED">
            <StackPanel Orientation="Horizontal"
                        Margin="4,4">
                <Button Width="32"
                        Height="32"
                        Margin="0,0,0,0"
                        Command="{Binding NewProjectCommand}"
                        Classes="toolbar-button"
                        ToolTip.Tip="New Project">
                    <Panel>
                        <Image Width="16"
                               Height="16"
                               Stretch="Uniform">
                            <Image.Source>
                                <svg:SvgImage Source="/Assets/Icons/Fluent/Toolbar/new-project.svg" />
                            </Image.Source>
                        </Image>
                    </Panel>
                </Button>

                <Button Width="32"
                        Height="32"
                        Margin="0,0,0,0"
                        Click="OpenProjectButton_OnClick"
                        Classes="toolbar-button"
                        ToolTip.Tip="Open Project">
                    <Panel>
                        <Image Width="16"
                               Height="16"
                               Stretch="Uniform">
                            <Image.Source>
                                <svg:SvgImage Source="/Assets/Icons/Fluent/Toolbar/open-project.svg" />
                            </Image.Source>
                        </Image>
                    </Panel>
                </Button>

                <Button Width="32"
                        Height="32"
                        Click="SaveProjectButton_OnClick"
                        Classes="toolbar-button"
                        ToolTip.Tip="Save Project">
                    <Panel>
                        <Image Width="16"
                               Height="16"
                               Stretch="Uniform">
                            <Image.Source>
                                <svg:SvgImage Source="/Assets/Icons/Fluent/Toolbar/save-project.svg" />
                            </Image.Source>
                        </Image>
                    </Panel>
                </Button>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2"
              ColumnDefinitions="280,5,*"
              Background="#FFEFEFEF">
            <Border Grid.Column="0"
                    BorderBrush="#FFC6C6C6"
                    BorderThickness="0,0,1,0"
                    Background="#FFF8F8F8">
                <Grid RowDefinitions="Auto,*">
                    <Border Padding="10,8"
                            BorderBrush="#FFD0D0D0"
                            BorderThickness="0,0,0,1"
                            Background="#FFF0F0F0">
                        <TextBlock Text="Resource Tree"
                                   FontWeight="SemiBold" />
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  Margin="6"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ResourceTree}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ResourceTreeItemViewModel">
                                    <controls:ResourceTreeItemView />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Background="#FFD3D3D3"
                          ResizeDirection="Columns"
                          ShowsPreview="True" />

            <Grid Grid.Column="2"
                  RowDefinitions="*,5,180">
                <Border Grid.Row="0"
                        BorderBrush="#FFC6C6C6"
                        BorderThickness="0,0,0,1"
                        Background="White">
                    <TabControl ItemsSource="{Binding OpenTabs}"
                                SelectedItem="{Binding SelectedTab}"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                ItemTemplate="{StaticResource EditorTabHeaderTemplate}"
                                ContentTemplate="{StaticResource EditorTabContentTemplate}" />
                </Border>

                <GridSplitter Grid.Row="1"
                              Background="#FFD3D3D3"
                              ResizeDirection="Rows"
                              ShowsPreview="True" />

                <Border Grid.Row="2"
                        Background="#FFFCFCFC">
                    <Grid RowDefinitions="Auto,*">
                        <Border Padding="10,8"
                                BorderBrush="#FFD0D0D0"
                                BorderThickness="0,1,0,1"
                                Background="#FFF0F0F0">
                            <TextBlock Text="Output"
                                       FontWeight="SemiBold" />
                        </Border>

                        <TextBox Grid.Row="1"
                                 Margin="8"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 Text="{Binding OutputText}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
